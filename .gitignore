# Root .gitignore for repo with backend/ (FastAPI) and frontend/ (React)

# Python artifacts (backend/)
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
env/
venv/
venv*/
ENV/
env.bak/
venv.bak/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos.
*.manifest
*.spec

# Unit test / coverage
.coverage
.coverage.*
.cache
pytest_cache/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# Pyre type checker
.pyre/

# mypy
.mypy_cache/

# IDE/editor
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Environment variables / secrets
.env
.env.*.local
.env.local
.env.production
.env.dev

# FastAPI / Uvicorn logs
*.log

# Database / SQLite
*.db
*.sqlite3
*.sqlite

# Migrations (if using Alembic) — keep source but ignore compiled/metafiles
backend/alembic/versions/*.pyc

# Node / JavaScript (frontend/)
node_modules/
frontend/node_modules/
# Yarn
yarn-error.log
yarn-debug.log
yarn-debug.log.*
# pnpm
pnpm-lock.yaml

# Build outputs
frontend/build/
frontend/dist/
frontend/.next/
frontend/out/

# Logs
npm-debug.log*
pnpm-debug.log*
lerna-debug.log*

# Env files for frontend
frontend/.env
frontend/.env.*.local
frontend/.env.local
frontend/.env.production
frontend/.env.development

# Mac / Windows system files
.DS_Store
Thumbs.db
ehthumbs.db

# Backup files
*~
*.swp
*.swo

# Coverage and test reports (frontend)
coverage/
frontend/coverage/

# TypeScript cache
*.tsbuildinfo

# Editor directories and files
*.idea/
.vscode/
*.code-workspace

# Git hooks and local configs
.git-credentials
*.local

# Logs and temporary files
logs/
*.log

# Optional: VS Code workspace settings (if you keep them private)
.vscode/settings.json

# Monorepo-specific: ignore per-package lockfiles if you prefer single root lockfile
# frontend/package-lock.json
# backend/package-lock.json

# Keep the following files tracked (examples/configs) by not ignoring them:
# !backend/requirements.txt
# !backend/pyproject.toml
# !frontend/package.json

# End of .gitignore
